# =========================================================================
# Spyfall Custom - Production & Local Environment Configuration Template
# =========================================================================

# -------------------------------------------------------------------------
# Server Basic Settings
# -------------------------------------------------------------------------
# NODE_ENV: Set to 'production' in cloud hosting or 'development' locally.
NODE_ENV=development

# PORT: The internal network port the Express application server listens on.
PORT=3000

# -------------------------------------------------------------------------
# Security, CORS & WebSocket Origin Configuration
# -------------------------------------------------------------------------
# ALLOWED_ORIGINS: Comma-separated list of secure domains permitted to connect.
# Never use wildcard '*' in production. Always list your actual domains.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# APP_URL: The public web address where this backend is deployed (e.g. Railway).
# Used for secure relative links, state synchronization, and CORS.
APP_URL=http://localhost:3000

# CLIENT_URL: The public web address where your frontend is deployed (e.g. Vercel).
CLIENT_URL=http://localhost:3000

# -------------------------------------------------------------------------
# Database Integration Settings (PostgreSQL / Supabase)
# -------------------------------------------------------------------------
# DATABASE_URL: Standard PostgreSQL connection string. If provided, the game 
# will persist custom word packs, match history logs, and room statistics.
# If omitted, the game automatically runs with high-performance in-memory fallback.
DATABASE_URL=postgresql://postgres:postgres_password@db.supabase.co:5432/postgres

# -------------------------------------------------------------------------
# AI Integration Secrets (Gemini API)
# -------------------------------------------------------------------------
# GEMINI_API_KEY: Standard API credential for AI-powered features.
# Configured via the Secrets / Environment panel of your deployment target.
GEMINI_API_KEY=your_gemini_api_key_here
